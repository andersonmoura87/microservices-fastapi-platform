{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "title": "SLO & Error Budget",
  "uid": "platform-slo",
  "tags": ["platform", "slo"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Availability (5m) — SLO 99%",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.99 },
              { "color": "green", "value": 0.999 }
            ]
          }
        }
      },
      "targets": [
        { "refId": "A", "expr": "1 - gateway:request_error_ratio:rate5m" }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "p95 latency (5m) — SLO 300ms",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.25 },
              { "color": "red", "value": 0.3 }
            ]
          }
        }
      },
      "targets": [{ "refId": "A", "expr": "gateway:request_latency_p95:5m" }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Burn rate — fast (5m)",
      "description": "Error ratio relative to the 1% budget. > 1 means the budget is burning faster than allowed; > 14.4 is a page-worthy fast burn.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 14.4 }
            ]
          }
        }
      },
      "targets": [
        { "refId": "A", "expr": "gateway:request_error_ratio:rate5m / 0.01" }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Burn rate — slow (1h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 6 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "(sum(rate(gateway_requests_total{status=~\"5..\"}[1h])) / clamp_min(sum(rate(gateway_requests_total[1h])), 1)) / 0.01"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Error ratio vs SLO threshold (1%)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      },
      "targets": [
        { "refId": "A", "expr": "gateway:request_error_ratio:rate5m", "legendFormat": "error ratio" },
        { "refId": "B", "expr": "vector(0.01)", "legendFormat": "SLO (1%)" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "p95 latency vs SLO threshold (300ms)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      },
      "targets": [
        { "refId": "A", "expr": "gateway:request_latency_p95:5m", "legendFormat": "p95" },
        { "refId": "B", "expr": "vector(0.3)", "legendFormat": "SLO (300ms)" }
      ]
    },
    {
      "id": 7,
      "type": "gauge",
      "title": "Error budget consumed (proxy, 1h window)",
      "description": "Share of the 1% error budget consumed over the last hour (capped at 100%).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.5 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "clamp_max((sum(rate(gateway_requests_total{status=~\"5..\"}[1h])) / clamp_min(sum(rate(gateway_requests_total[1h])), 1)) / 0.01, 1)"
        }
      ]
    }
  ]
}
